[Unit]
Description=Fuzz Pipeline LAN dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/azanul/fuzz-pipeline
EnvironmentFile=-/home/azanul/.config/fuzz-pipeline/env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/azanul/fuzz-pipeline/bin/fuzzctl --runtime native dashboard --host 0.0.0.0 --port 8089 --token-env FUZZ_DASHBOARD_TOKEN
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=default.target
